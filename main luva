    aboutDlg.show()
    about_back.onClick=function() aboutDlg.dismiss() end
    whatsapp_btn.onClick=function()
      pcall(function()
        local url = "https://api.whatsapp.com/send?phone=923260310276"
        local intent = Intent(Intent.ACTION_VIEW)
        intent.setData(Uri.parse(url))
        intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
        context.startActivity(intent)
        showMessage("Opening WhatsApp Chat...")
      end)
    end
  end

  settings_btn.onClick=function()
    local setLayout = {
      ScrollView, layout_width="fill",
      {LinearLayout, orientation="vertical", padding="20dp",
        {TextView, text="Audio Settings", textSize="18sp", typeface=Typeface.DEFAULT_BOLD, layout_marginBottom="15dp"},
        {Button, id="pitch_toggle_btn", text="Voice Pitch: " .. tostring(currentPitch), layout_width="fill"},
        {Button, id="speed_toggle_btn", text="Speech Speed: " .. tostring(currentSpeed), layout_width="fill", layout_marginTop="10dp"},
        {Button, id="eq_toggle_btn", text="Equalizer Mode: " .. tostring(currentEQPreset), layout_width="fill", layout_marginTop="10dp"},
        {CheckBox, id="auto_play_cb", text="Auto Play Next", checked=isAutoPlay, layout_marginTop="15dp"},
        {CheckBox, id="repeat_cb", text="Repeat Mode", checked=isRepeat},
        {Button, id="set_back", text="Back", layout_marginTop="20dp", layout_width="fill"}}
    }
    local setDlg = LuaDialog(context).setView(loadlayout(setLayout))
    setDlg.show()
    set_back.onClick=function() setDlg.dismiss() end

    pitch_toggle_btn.onClick=function()
      currentPitch = currentPitch + 0.1
      if currentPitch > 1.51 then currentPitch = 1.0 end
      currentPitch = tonumber(string.format("%.1f", currentPitch))
      pitch_toggle_btn.setText("Voice Pitch: " .. tostring(currentPitch))
      showMessage("Pitch " .. tostring(currentPitch))
      if mediaPlayer and mediaPlayer.isPlaying() then
        pcall(function() local params = mediaPlayer.getPlaybackParams() params.setPitch(currentPitch) mediaPlayer.setPlaybackParams(params) end)
      end
    end

    speed_toggle_btn.onClick=function()
      currentSpeed = currentSpeed + 0.1
      if currentSpeed > 1.51 then currentSpeed = 1.0 end
      currentSpeed = tonumber(string.format("%.1f", currentSpeed))
      speed_toggle_btn.setText("Speech Speed: " .. tostring(currentSpeed))
      showMessage("Speed " .. tostring(currentSpeed))
      if mediaPlayer and mediaPlayer.isPlaying() then
        pcall(function() local params = mediaPlayer.getPlaybackParams() params.setSpeed(currentSpeed) mediaPlayer.setPlaybackParams(params) end)
      end
    end

    eq_toggle_btn.onClick=function()
      currentEQPreset = currentEQPreset + 1
      if currentEQPreset > 5 then currentEQPreset = 0 end
      eq_toggle_btn.setText("Equalizer Mode: " .. tostring(currentEQPreset))
      showMessage("Equalizer Mode " .. tostring(currentEQPreset))
      if eq then pcall(function() eq.usePreset(currentEQPreset) end) end
    end

    auto_play_cb.setOnCheckedChangeListener(CompoundButton.OnCheckedChangeListener{onCheckedChanged=function(v, c) isAutoPlay = c end})
    repeat_cb.setOnCheckedChangeListener(CompoundButton.OnCheckedChangeListener{onCheckedChanged=function(v, c) isRepeat = c end})
  end
end

play_pause_btn.onClick=function()
  if #filteredFiles == 0 then return end
  if not isStarted then 
    playMedia(currentTrackIndex)
  else
    if mediaPlayer and mediaPlayer.isPlaying() then 
      mediaPlayer.pause() 
      play_pause_btn.setText("Play")
    elseif mediaPlayer then 
      mediaPlayer.start()
      play_pause_btn.setText("Pause")
    end
  end
end

