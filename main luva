local isAutoPlay = false
local isRepeat = false

local currentPitch = 1.0
local currentSpeed = 1.0
local currentEQPreset = 0

local playMedia

local audioManager = context.getSystemService(Context.AUDIO_SERVICE)
local focusChangeListener = AudioManager.OnAudioFocusChangeListener{
  onAudioFocusChange=function(focusChange)
    if not mediaPlayer then return end
    if focusChange == AudioManager.AUDIOFOCUS_LOSS_TRANSIENT_CAN_DUCK then
      mediaPlayer.setVolume(0.2, 0.2)
    elseif focusChange == AudioManager.AUDIOFOCUS_GAIN then
      mediaPlayer.setVolume(1.0, 1.0)
    elseif focusChange == AudioManager.AUDIOFOCUS_LOSS then
      if mediaPlayer.isPlaying() then mediaPlayer.pause() play_pause_btn.setText("Play") end
    end
  end
}

local function stopAndClose()
  if audioManager and focusChangeListener then audioManager.abandonAudioFocus(focusChangeListener) end
  if eq then eq.release() eq = nil end
  if mediaPlayer then
    if mediaPlayer.isPlaying() then mediaPlayer.stop() end
    mediaPlayer.release()
    mediaPlayer = nil
  end
  if activity then 
    activity.finish() 
  end
end

