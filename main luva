playMedia = function(index)
  if #filteredFiles == 0 or not mediaPlayer then return end
  if index < 1 then index = #filteredFiles end
  if index > #filteredFiles then index = 1 end
  currentTrackIndex = index
  
  if audioManager then
    audioManager.requestAudioFocus(focusChangeListener, AudioManager.STREAM_MUSIC, AudioManager.AUDIOFOCUS_GAIN_TRANSIENT_MAY_DUCK)
  end

  mediaPlayer.reset()
  mediaPlayer.setDataSource(filteredFiles[currentTrackIndex])
  mediaPlayer.prepare()
  
  if not eq and mediaPlayer.getAudioSessionId() ~= 0 then
    pcall(function()
      eq = Equalizer(0, mediaPlayer.getAudioSessionId())
      eq.setEnabled(true)
      if currentEQPreset <= eq.getNumberOfPresets() - 1 then
        eq.usePreset(currentEQPreset)
      end
    end)
  end

  mediaPlayer.setOnCompletionListener(MediaPlayer.OnCompletionListener{
    onCompletion=function(mp)
      if isRepeat then
        playMedia(currentTrackIndex)
      elseif isAutoPlay then
        playMedia(currentTrackIndex + 1)
      else
        play_pause_btn.setText("Play")
      end
    end
  })

  mediaPlayer.start()

  pcall(function()
    local params = mediaPlayer.getPlaybackParams()
    params.setPitch(currentPitch)
    params.setSpeed(currentSpeed)
    mediaPlayer.setPlaybackParams(params)
  end)

  play_pause_btn.setText("Pause")
  
  if not isStarted then
    isStarted = true
    left_controls.setVisibility(View.VISIBLE)
    right_controls.setVisibility(View.VISIBLE)
  end
end

local function scanMediaFiles()
  audioFiles, audioNames, videoFiles, videoNames = {}, {}, {}, {}
  local storagePath = os.getenv("EXTERNAL_STORAGE")
  if not storagePath then return end
  
  local function scan(dir)
    local files = dir.listFiles()
    if files then
      for i=0, #files-1 do
        local f = files[i]
        local n = tostring(f.getName())
        if f.isDirectory() then 
          if not n:find("^%.") and n ~= "Android" then scan(f) end
        elseif f.isFile() then
          local ln = n:lower()
          if ln:find("%.mp3$") or ln:find("%.wav$") or ln:find("%.m4a$") or ln:find("%.ogg$") then
            table.insert(audioFiles, f.getAbsolutePath())
            table.insert(audioNames, n)
          elseif ln:find("%.mp4$") or ln:find("%.mkv$") or ln:find("%.3gp$") then
            table.insert(videoFiles, f.getAbsolutePath())
            table.insert(videoNames, n)
          end
        end
      end
    end
  end
  scan(File(storagePath))
end

local function filterMediaList(keyword)
  filteredFiles = {}
  filteredNames = {}
  
  local sourceFiles = currentListMode == "audio" and audioFiles or videoFiles
  local sourceNames = currentListMode == "audio" and audioNames or videoNames
  
  keyword = tostring(keyword):lower():gsub("^%s*(.-)%s*$", "%1")
  
  if keyword == "" then
    if sourceFiles and #sourceFiles > 0 then
      for i=1, #sourceFiles do
        table.insert(filteredFiles, sourceFiles[i])
        table.insert(filteredNames, sourceNames[i])
      end
    end
  else
    for i=1, #sourceNames do
      local currentName = tostring(sourceNames[i]):lower()
      if currentName:find(keyword, 1, true) then
        table.insert(filteredNames, sourceNames[i])
        table.insert(filteredFiles, sourceFiles[i])
      end
    end
  end
  
  if #filteredNames == 0 then
    local noFilesMsg = currentListMode == "audio" and "No audio files found" or "No video files found"
    local adapter = ArrayAdapter(context, android.R.layout.simple_list_item_1, {noFilesMsg})
    media_list.setAdapter(adapter)
  else
    local adapter = ArrayAdapter(context, android.R.layout.simple_list_item_1, filteredNames)
    media_list.setAdapter(adapter)
  end
end

scanMediaFiles()

if currentListMode == "audio" then
  for i=1, #audioFiles do
    table.insert(filteredFiles, audioFiles[i])
    table.insert(filteredNames, audioNames[i])
  end
else
  for i=1, #videoFiles do
    table.insert(filteredFiles, videoFiles[i])
    table.insert(filteredNames, videoNames[i])
  end
end

filterMediaList("")

search_box.addTextChangedListener(TextWatcher{
  onTextChanged=function(s, start, before, count)
    filterMediaList(s)
  end
})

local function refreshListView()
  scanMediaFiles()
  search_box.setText("")
  filterMediaList("")
end

switch_list_btn.onClick=function()
  if mediaPlayer and mediaPlayer.isPlaying() then
    mediaPlayer.stop()
  end

  if currentListMode == "audio" then
    currentListMode = "video"
    switch_list_btn.setText("Video List")
  else
    currentListMode = "audio"
    switch_list_btn.setText("Audio List")
  end
  
  search_box.setText("") 
  filterMediaList("")
  
  isStarted = false
  currentTrackIndex = 1
  play_pause_btn.setText("Play")
  left_controls.setVisibility(View.GONE)
  right_controls.setVisibility(View.GONE)
  showMessage(currentListMode == "audio" and "Audio List Switching" or "Videos List Switching")
end

media_list.onItemClick=function(p, v, pos)
  if #filteredFiles == 0 then return end
  playMedia(pos+1) 
end

more_options_btn.onClick=function()
  local menuLayout = {
    LinearLayout, orientation="vertical", layout_width="fill", padding="20dp",
    {TextView, text="More Options", textSize="20sp", typeface=Typeface.DEFAULT_BOLD, layout_gravity="center", layout_marginBottom="15dp"},
    {Button, id="settings_btn", text="Settings", layout_width="fill"},
    {Button, id="ringtone_btn", text="Ringtone", layout_width="fill", layout_marginTop="10dp"},
    {Button, id="share_file_btn", text="Share File", layout_width="fill", layout_marginTop="10dp"},
    {Button, id="delete_btn", text="Delete", layout_width="fill", layout_marginTop="10dp"},
    {Button, id="about_btn", text="About", layout_width="fill", layout_marginTop="10dp"},
    {Button, id="menu_back", text="Back", layout_width="fill", layout_marginTop="20dp"},
  }
  local menuDlg = LuaDialog(context).setView(loadlayout(menuLayout))
  menuDlg.show()
  menu_back.onClick=function() menuDlg.dismiss() end

  share_file_btn.onClick=function()
    if not isStarted or #filteredFiles == 0 or not filteredFiles[currentTrackIndex] then
      showMessage("Please select or play a file first")
      return
    end
    
    pcall(function()
      local filePath = filteredFiles[currentTrackIndex]
      local file = File(filePath)
      if file.exists() then
        local builder = StrictMode.VmPolicy.Builder()
        StrictMode.setVmPolicy(builder.build())

        local intent = Intent(Intent.ACTION_SEND)
        if currentListMode == "audio" then
          intent.setType("audio/*")
        else
          intent.setType("video/*")
        end
        
        local fileUri = Uri.fromFile(file)
        intent.putExtra(Intent.EXTRA_STREAM, fileUri)
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
        
        local chooser = Intent.createChooser(intent, "Share via")
        chooser.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
        context.startActivity(chooser)
      else
        showMessage("File does not exist")
      end
    end)
  end

  ringtone_btn.onClick=function()
    if currentListMode == "video" then
      showMessage("Error: Ringtone can only be set for audio files")
      return
    end
    if not isStarted or #filteredFiles == 0 or not filteredFiles[currentTrackIndex] then
      showMessage("No audio file playing or selected")
      return
    end
    local ringLayout = {
      LinearLayout, orientation="vertical", padding="20dp",
      {TextView, text="Do you want to set this audio as your phone Ringtone?", textSize="16sp", layout_marginBottom="20dp"},
      {LinearLayout, orientation="horizontal", gravity="right", layout_width="fill",
        {Button, id="ring_cancel", text="Cancel"},
        {Button, id="ring_ok", text="OK", layout_marginLeft="10dp"}}
    }
    local ringDlg = LuaDialog(context).setView(loadlayout(ringLayout))
    ringDlg.show()
    ring_cancel.onClick=function() ringDlg.dismiss() end
    ring_ok.onClick=function()
      pcall(function()
        local filePath = filteredFiles[currentTrackIndex]
        local file = File(filePath)
        if file.exists() then
          if Settings.System.canWrite(context) then
            RingtoneManager.setActualDefaultRingtoneUri(context, RingtoneManager.TYPE_RINGTONE, Uri.fromFile(file))
            showMessage("Ringtone Set Successfully")
            ringDlg.dismiss()
            menuDlg.dismiss()
          else
            showMessage("Please allow modify system settings permission")
            local intent = Intent(Settings.ACTION_MANAGE_WRITE_SETTINGS)
            intent.setData(Uri.parse("package:" .. context.getPackageName()))
            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
            context.startActivity(intent)
          end
        end
      end)
    end
  end

  delete_btn.onClick=function()
    if not isStarted or #filteredFiles == 0 or not filteredFiles[currentTrackIndex] then
      showMessage("No file selected to delete")
      return
    end
    local deleteLayout = {
      LinearLayout, orientation="vertical", padding="20dp",
      {TextView, text="Are you sure you want to delete this file permanently?", textSize="16sp", layout_marginBottom="20dp"},
      {LinearLayout, orientation="horizontal", gravity="right", layout_width="fill",
        {Button, id="del_cancel", text="Cancel"},
        {Button, id="del_ok", text="OK", layout_marginLeft="10dp"}}
    }
    local deleteDlg = LuaDialog(context).setView(loadlayout(deleteLayout))
    deleteDlg.show()
    del_cancel.onClick=function() deleteDlg.dismiss() end
    del_ok.onClick=function()
      pcall(function()
        local filePath = filteredFiles[currentTrackIndex]
        local file = File(filePath)
        if file.exists() then
          if mediaPlayer and mediaPlayer.isPlaying() then
            mediaPlayer.stop()
            play_pause_btn.setText("Play")
          end
          file.delete()
          showMessage("File Deleted")
          refreshListView()
          deleteDlg.dismiss()
          menuDlg.dismiss()
        end
      end)
    end
  end

  about_btn.onClick=function()
    local aboutLayout = {
      LinearLayout, orientation="vertical", padding="20dp",
      {TextView, text="Media Player v3.0\nDeveloped by: qaramali\nAll Rights Reserved.", gravity="center", layout_marginBottom="15dp"},
